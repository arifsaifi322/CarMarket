<%if(success && success.length){%>
    <div class="alert alert-success alert-dismissible fade show mt-3 col-6 offset-2" role="alert">
        <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<%}%>
<%if(errorr && errorr.length){%>
    <div class="alert alert-danger alert-dismissible fade show mt-3 col-6 offset-2" role="alert">
        <%= errorr %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<%}%>